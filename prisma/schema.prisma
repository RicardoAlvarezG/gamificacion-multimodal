// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model Usuario {
  id                 Int      @id @default(autoincrement())
  nombre             String
  apellido           String?
  correo             String   @unique
  usuario            String   @unique
  password           String
  rol                Rol
  codigoInstitucional String?  @unique
  institucionId      Int?
  estado             String   @default("activo")
  createdAt          DateTime @default(now())

  institucion        Institucion? @relation(fields: [institucionId], references: [id])
  aulasDocente       Aula[]       @relation("DocenteAulas")
  aulasCreadas       Aula[]       @relation("AulasCreadas")
}

model Institucion {
  id        Int      @id @default(autoincrement())
  nombre    String
  codigo    String   @unique
  createdAt DateTime @default(now())

  usuarios  Usuario[]
  aulas     Aula[]
}

model Aula {
  id            Int      @id @default(autoincrement())
  nombre        String
  turno         String
  institucionId Int?
  docenteId     Int?
  creadoPorId   Int?
  createdAt     DateTime @default(now())

  institucion   Institucion? @relation(fields: [institucionId], references: [id])
  docente       Usuario?     @relation("DocenteAulas", fields: [docenteId], references: [id])
  estudiantes   Estudiante[]
  creadoPor     Usuario?     @relation("AulasCreadas", fields: [creadoPorId], references: [id])
}

model Estudiante {
  id        Int      @id @default(autoincrement())
  nombres   String
  apellidos String
  aulaId    Int
  createdAt DateTime @default(now())

  aula      Aula @relation(fields: [aulaId], references: [id])
  perfil    PerfilGamificado?
  puntajes  Puntaje[]
  progresosCapacidad ProgresoCapacidad[]
  evidenciasCapacidad EvidenciaCapacidad[]
}

model PerfilGamificado {
  id           Int      @id @default(autoincrement())
  estudianteId Int      @unique
  avatar       String?
  nivel        Int      @default(1)
  puntosTotal  Int      @default(0)
  createdAt    DateTime @default(now())

  estudiante   Estudiante @relation(fields: [estudianteId], references: [id])
}

model Puntaje {
  id           Int      @id @default(autoincrement())
  estudianteId Int
  puntos       Int
  motivo       String
  createdAt    DateTime @default(now())

  estudiante   Estudiante @relation(fields: [estudianteId], references: [id])
}

model Capacidad {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  nombre      String
  area        String
  color       String
  descripcion String?
  createdAt   DateTime @default(now())

  juegos      JuegoCapacidad[]
  progresos   ProgresoCapacidad[]
  evidencias  EvidenciaCapacidad[]
}

model Juego {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  grado       String
  descripcion String?
  createdAt   DateTime @default(now())

  capacidades JuegoCapacidad[]
  evidencias   EvidenciaCapacidad[]
}

model JuegoCapacidad {
  id          Int @id @default(autoincrement())
  juegoId     Int
  capacidadId Int

  juego       Juego     @relation(fields: [juegoId], references: [id])
  capacidad   Capacidad @relation(fields: [capacidadId], references: [id])

  @@unique([juegoId, capacidadId])
}

model ProgresoCapacidad {
  id           Int      @id @default(autoincrement())
  estudianteId Int
  capacidadId  Int
  puntos        Int      @default(0)
  nivel         String   @default("EN_INICIO")
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  estudiante    Estudiante @relation(fields: [estudianteId], references: [id])
  capacidad     Capacidad  @relation(fields: [capacidadId], references: [id])

  @@unique([estudianteId, capacidadId])
}

model EvidenciaCapacidad {
  id           Int      @id @default(autoincrement())
  estudianteId Int
  capacidadId  Int
  juegoId       Int
  puntos        Int      @default(10)
  createdAt     DateTime @default(now())

  estudiante    Estudiante @relation(fields: [estudianteId], references: [id])
  capacidad     Capacidad  @relation(fields: [capacidadId], references: [id])
  juego         Juego      @relation(fields: [juegoId], references: [id])
}

enum Rol {
  ADMIN
  DOCENTE
}